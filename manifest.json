{
  "manifest_version": 3,
  "name": "F2P Addon",
  "version": "0.1",
  "description": "F2P Addon",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://demonicscans.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://demonicscans.org/active_wave.php*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    
  }
}